# Copy to ".env" for local development:  cp .env.example .env
#
# These are read by the Rust core at startup (see src-tauri/src/config.rs).
# All have safe defaults, so the app runs with no .env at all.

# Base URL of the central cloud Ticket API (used by the future sync layer).
CLOUD_API_URL=http://localhost:8080

# Log verbosity: error | warn | info | debug | trace
APP_LOG_LEVEL=info

# Override the local SQLite filename (stored in the OS app-data directory).
# Leave unset to use the default.
# APP_DB_FILENAME=ticketing.db
